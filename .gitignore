services/ml-inference/audio-storage/

apps/*/node_modules/
apps/*/dist/
packages/*/node_modules/
packages/*/dist/
services/*/target/

# Secrets / env — never commit (see AGENTS.md hard boundaries)
.env
.env.*
!.env.example
secrets/
*.pem
scripts/stack.env

# Tooling / OS
package-lock.json
.DS_Store
*.log
.serena/
.claude/launch.json
.cocoindex_code/

# Python artifacts
__pycache__/
*.pyc

# cargo-mutants output (local mutation-testing runs, not CI-tracked)
mutants.out/
mutants.out.old/

# Unrelated stray project (kept on disk, not part of the platform)
UnpredectableGAME/

# Database backups (learner data — never commit)
/backups/
*.dump
