# Quran AI — Environment Configuration
#
# Copy to .env and fill in real values.
# NEVER commit the .env file — only .env.example is tracked.

# === Database ===
POSTGRES_PASSWORD=change-this-to-a-strong-password
DATABASE_URL=postgresql://hawzhin:${POSTGRES_PASSWORD}@localhost:5432/quran_ai

# === Platform API ===
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
PLATFORM_API_BIND=127.0.0.1:8080
# Set to 1 for local dev only — allows weak secrets and header-based auth
ALLOW_INSECURE_DEFAULTS=0

# === Realtime Gateway ===
REALTIME_GATEWAY_BIND=127.0.0.1:8081
REALTIME_GATEWAY_TICKET_SECRET=change-this-to-a-random-secret-at-least-32-chars
ML_INFERENCE_URL=http://127.0.0.1:8090
GATEWAY_TENANT_ID=hikmah-pilot-erbil

# === ML Inference ===
ML_API_KEY=change-this-to-a-random-api-key
ML_INFERENCE_PORT=8090
ML_MODEL_VERSION=ml-aligner-v0.2
AUDIO_STORAGE_DIR=./services/ml-inference/audio-storage
ASR_SERVICE_URL=http://127.0.0.1:8091

# === ASR Inference ===
ASR_PORT=8091
ASR_MODEL=base
ASR_HOST=127.0.0.1

# === Web Frontend ===
VITE_PLATFORM_API_URL=http://127.0.0.1:8080
VITE_REALTIME_GATEWAY_URL=ws://127.0.0.1:8081
